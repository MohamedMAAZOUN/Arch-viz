# Copy to .env (loaded by `pnpm dev` via tsx --env-file) and adjust.
# Validation lives in src/config.ts — the server refuses to boot on bad config.

# --- required -----------------------------------------------------------
DATABASE_URL=postgres://arch_vis:arch_vis@localhost:5432/arch_vis

# --- optional (defaults shown) -------------------------------------------
# NODE_ENV=development
# HOST=0.0.0.0
# PORT=3001

# --- auth modes (ADR 0014: both can coexist; each toggleable) ------------
# AUTH_LOCAL_ENABLED=true
# AUTH_OIDC_ENABLED=false
# When AUTH_OIDC_ENABLED=true, all four OIDC_* values are required:
# OIDC_ISSUER_URL=https://am.example.com/am/oauth2/realms/root/realms/myrealm
# OIDC_CLIENT_ID=arch-vis
# OIDC_CLIENT_SECRET=change-me
# OIDC_REDIRECT_URI=https://app.example.com/auth/oidc/callback
