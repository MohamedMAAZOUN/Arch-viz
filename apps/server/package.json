{
  "name": "@arch-vis/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Architecture Visualizer backend — Fastify + Drizzle + Postgres + Hocuspocus (ADR 0014).",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@arch-vis/schema": "workspace:*",
    "@fastify/rate-limit": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
