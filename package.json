{
  "name": "arch-vis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Architecture Visualizer — workspace root (apps/web, apps/server, packages/schema)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @arch-vis/web dev",
    "build": "pnpm -r build",
    "preview": "pnpm --filter @arch-vis/web preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"apps/*/src/**/*.{ts,tsx,css,md,json,yaml}\" \"packages/*/src/**/*.{ts,tsx,css,md,json,yaml}\"",
    "format:check": "prettier --check \"apps/*/src/**/*.{ts,tsx,css,md,json,yaml}\" \"packages/*/src/**/*.{ts,tsx,css,md,json,yaml}\"",
    "test": "pnpm --filter @arch-vis/web test",
    "test:run": "pnpm -r test:run",
    "test:e2e": "pnpm --filter @arch-vis/web test:e2e",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "eslint": "9.18.0",
    "eslint-import-resolver-typescript": "3.7.0",
    "eslint-plugin-import-x": "4.6.1",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.18",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": "6.0.7"
    }
  }
}
